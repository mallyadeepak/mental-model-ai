{
  "name": "@mental-model/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for generating mental model diagrams in Claude Code",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/mental-model-ai.git",
    "directory": "packages/mcp-server"
  },
  "type": "module",
  "bin": {
    "mental-model-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["mcp", "claude", "mental-model", "diagram", "visualization"],
  "license": "MIT"
}
